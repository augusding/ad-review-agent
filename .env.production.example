# ============================================================
# 生产环境配置模板
# 复制为 .env 并填写真实值，不要提交到 git
# ============================================================

# -------------------- LLM API（必填） --------------------

# DeepSeek — 文案分析、语义理解、落地页分析
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DashScope（通义千问视觉模型）— 图片/视频多模态审核
DASHSCOPE_API_KEY=sk-your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-max

# -------------------- 数据库（必填） --------------------

# PostgreSQL — asyncpg 驱动，与 docker-compose 中的 db 服务对应
DATABASE_URL=postgresql+asyncpg://ad_review:your-strong-password@db:5432/ad_review

# docker-compose 使用的 PostgreSQL 配置
POSTGRES_DB=ad_review
POSTGRES_USER=ad_review
POSTGRES_PASSWORD=your-strong-password

# Redis — 人工复核队列
REDIS_URL=redis://localhost:6379/0

# -------------------- 决策阈值（可选，有默认值） --------------------

# AUTO_PASS_THRESHOLD=0.92
# AUTO_REJECT_THRESHOLD=0.92
# HUMAN_REVIEW_LOWER=0.70

# -------------------- 运行配置 --------------------

LOG_LEVEL=WARNING

# 复制此文件为 .env 并填写真实值
# 不要把 .env 提交到 git

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DashScope API（通义千问视觉模型，用于图片/视频多模态审核）
DASHSCOPE_API_KEY=sk-your-dashscope-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-max

# 数据库
DATABASE_URL=sqlite+aiosqlite:///ad_review.db
REDIS_URL=redis://localhost:6379/0

# 决策阈值（可选，有默认值）
# AUTO_PASS_THRESHOLD=0.92
# AUTO_REJECT_THRESHOLD=0.92
# HUMAN_REVIEW_LOWER=0.70
# IMAGE_AUTO_THRESHOLD=0.92

# API 认证（逗号分隔的合法 Key，为空则不启用认证）
API_KEYS=your-api-key-1,your-api-key-2
RATE_LIMIT_PER_MINUTE=100

# 管理后台认证（默认管理员，首次启动自动创建）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123456

# 阿里云内容安全（双重验证，为空则禁用）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_GREEN_ENDPOINT=green-cip.cn-shanghai.aliyuncs.com
ALIYUN_GREEN_ENABLED=true

# 音频检测（视频语音转写+违规检测）
AUDIO_CHECK_ENABLED=true
AUDIO_MAX_DURATION_SECONDS=300

# ========== 素材接入方式（三选一或多选）==========

# 方式A：HTTP Webhook 推送
INGEST_WEBHOOK_SECRET=          # 空则不校验签名
INGEST_FIELD_MAPPING={}         # 字段映射JSON

# 方式B：消息队列
MQ_TYPE=none                    # kafka / rocketmq / none
MQ_BROKERS=localhost:9092
MQ_TOPIC=ad_creative_submit
MQ_GROUP_ID=ad-review-agent
MQ_CONSUME_RATIO=0.1            # 灰度消费比例

# 方式C：手动上传（默认启动，无需配置）

# 日志级别
LOG_LEVEL=INFO
